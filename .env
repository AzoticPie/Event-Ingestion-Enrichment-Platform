APP_NAME=event-ingestion-platform
ENVIRONMENT=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_VITE_API_BASE_URL=http://localhost:8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=event_platform
POSTGRES_USER=event_platform
POSTGRES_PASSWORD=event_platform

REDIS_HOST=redis
REDIS_PORT=6379

AGGREGATE_ROLLUP_ENABLED=false
AGGREGATE_ROLLUP_REFRESH_LOOKBACK_MINUTES=180
AGGREGATE_ROLLUP_REFRESH_INTERVAL_SECONDS=60
AGGREGATE_ROLLUP_REFRESH_TENANTS_PER_TICK=100
AGGREGATE_ROLLUP_REFRESH_MAX_INFLIGHT_TENANT_TASKS=20
AGGREGATE_ROLLUP_BACKFILL_CHUNK_MINUTES=1440
AGGREGATE_ROLLUP_BACKFILL_MAX_CHUNKS_PER_TASK=24
AGGREGATE_ROLLUP_LOCK_RETRY_MAX_ATTEMPTS=8
AGGREGATE_ROLLUP_LOCK_RETRY_BASE_SECONDS=5
AGGREGATE_ROLLUP_MAX_WINDOW_MINUTES=10080
CELERY_ROLLUP_QUEUE=rollup.default

ENABLE_READINESS_DEPENDENCY_CHECKS=true

